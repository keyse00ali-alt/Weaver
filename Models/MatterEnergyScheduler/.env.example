# Required for live ENTSO-E day-ahead prices
ENTSOE_API_KEY=your_entsoe_token_here

# Optional. Leave unset to attempt live prices when ENTSOE_API_KEY is configured.
# Set to 0 to force fallback prices for offline testing.
# WEAVER_LIVE_PRICES=1

# Matter commissioning/discovery uses a Matter Server on a Raspberry Pi.
MATTER_SERVER_WS_URL=ws://RASPBERRY_PI_IP:5580/ws

# Comma-separated browser origins allowed to call this API.
# Use "*" only for local testing. For internet deployment, set your website origin.
FRONTEND_ORIGINS=http://localhost:3000,https://your-weaver-site.example

# Bind publicly when running behind a reverse proxy/tunnel.
API_HOST=0.0.0.0
API_PORT=8000
